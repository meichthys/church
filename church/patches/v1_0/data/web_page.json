  "main_section_html": "<div class=\"row\">  \n{% set belief_docs = frappe.get_list(\"Belief\", fields=[\"name\"], filters={\"publish\": 1}, ignore_permissions=True) %}\n{% for doc in belief_docs %}\n    {% set belief = frappe.get_doc(\"Belief\", doc.name) %}\n    <div class=\"col-md-4 mb-4\">  \n        <div class=\"card h-100\">  \n            <div class=\"card-header\"><strong>{{ belief.title }}</strong></div>  \n            <div class=\"card-body\">  \n                <p class=\"card-text\">{{ belief.belief_statement }}</p>  \n            </div>\n            <div class=\"card-footer\">\n                {% for row in belief.bible_references %}  \n                    <div class=\"small text-muted\">{{ row.reference }}</div>  \n                {% endfor %}  \n            </div>\n        </div>  \n    </div>  \n{% endfor %}  \n</div>",
